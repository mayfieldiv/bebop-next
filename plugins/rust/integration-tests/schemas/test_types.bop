// test_types.bop
//
// Comprehensive test schema for the Rust code generator.
// Covers: enums, flags, fixed-size structs, variable-size structs,
// messages, unions, arrays, maps, byte arrays, fixed arrays,
// and cross-type references.

edition = "2026"
package test

import "bebop/decorators.bop"

/// Simple enum with uint8 base type.
enum Color : uint8 {
    UNKNOWN = 0;
    RED = 1;
    GREEN = 2;
    BLUE = 3;
}

/// Flags enum with bitwise operations.
@flags
enum Permissions : uint8 {
    NONE = 0;
    READ = 1;
    WRITE = 2;
    EXECUTE = 4;
    ALL = 7;
}

/// Constants used to validate Rust const generation.
const byte PCase = 0x12;
const int32 exampleConstInt32 = -123;
const uint64 exampleConstUint64 = 0x123ffffffff;
const float64 exampleConstFloat64 = 123.45678e9;
const float64 exampleConstInf = inf;
const float64 exampleConstNegInf = -inf;
const float64 exampleConstNan = nan;
const bool exampleConstFalse = false;
const bool exampleConstTrue = true;
const uint32 HTTP_STATUS_OK = 200;
const bool FEATURE_FLAG_ENABLED = true;
const string exampleConstString = "hello ""world""
with newlines";
const guid exampleConstGuid = "e215a946-b26f-4567-a276-13136f0a1708";
const float16 exampleConstF16 = 1.5;
const bfloat16 exampleConstBf16 = 1.5;
const float16 exampleConstF16Inf = inf;
const bfloat16 exampleConstBf16NegInf = -inf;
const float16 exampleConstF16Nan = nan;
const bfloat16 exampleConstBf16Nan = nan;
const float16 exampleConstF16FromInt = 1;
const bfloat16 exampleConstBf16FromInt = 2;

/// Fixed-size struct (all scalar fields).
struct Point {
    x: float32;
    y: float32;
}

/// Fixed-size struct referencing another struct and an enum.
struct Pixel {
    position: Point;
    color: Color;
    alpha: uint8;
}

/// Variable-size struct with a string field (needs lifetime / Cow).
struct Person {
    name: string;
    age: uint32;
}

/// Variable-size struct with a byte array field (needs lifetime / Cow).
struct BinaryPayload {
    tag: uint32;
    data: byte[];
}

/// Message with various field types: scalars, strings, arrays, maps.
message UserProfile {
    display_name(1): string;
    email(2): string;
    age(3): uint32;
    active(4): bool;
    tags(5): string[];
    metadata(6): map[string, string];
    permissions(7): Permissions;
}

/// Message referencing fixed-size and enum defined types.
message DrawCommand {
    target(1): Point;
    color(2): Color;
    label(3): string;
    thickness(4): float32;
}

/// Struct used as a union branch (variable-size due to string field).
struct TextLabel {
    position: Point;
    text: string;
}

/// Union with type-ref branches covering fixed and variable inner types.
/// Forward-compatible: unknown discriminators are preserved and round-tripped.
@forward_compatible
union Shape {
    point(1): Point;
    pixel(2): Pixel;
    label(3): TextLabel;
}

/// Strict union: unknown discriminators are rejected with DecodeError.
union StrictShape {
    point(1): Point;
    pixel(2): Pixel;
}

/// Forward-compatible enum: unknown discriminator values become Unknown(T).
@forward_compatible
enum Priority : uint8 {
    UNSPECIFIED = 0;
    LOW = 1;
    MEDIUM = 2;
    HIGH = 3;
}

/// Strict message: unknown field tags are rejected with DecodeError.
message StrictConfig {
    name(1): string;
    value(2): uint32;
}

/// Forward-compatible message: unknown field tags are silently skipped.
@forward_compatible
message FlexConfig {
    name(1): string;
    value(2): uint32;
}

/// Forward-compatible flags: unknown bit patterns are accepted.
@forward_compatible
@flags
enum FlexPermissions : uint8 {
    NONE = 0;
    READ = 1;
    WRITE = 2;
}

/// Fixed-array struct (compile-time known element count).
struct Matrix2x2 {
    values: float32[4];
}

/// Fixed-size and variable-size half-precision scalar coverage.
struct HalfPrecisionScalars {
    f16_val: float16;
    bf16_val: bfloat16;
}

struct HalfPrecisionArrays {
    f16_dynamic: float16[];
    bf16_dynamic: bfloat16[];
    f16_fixed: float16[4];
    bf16_fixed: bfloat16[4];
}

message HalfPrecisionMessage {
    f16_val(1): float16;
    bf16_val(2): bfloat16;
    f16_arr(3): float16[];
    bf16_arr(4): bfloat16[];
}

/// Struct with multiple string fields (all need Cow).
struct Address {
    street: string;
    city: string;
    country: string;
    zip_code: string;
}

/// Message with array-of-defined-type and nested references.
message Scene {
    shapes(1): Shape[];
    background(2): Color;
    title(3): string;
}

/// Message with map[string, defined-type] value.
message Inventory {
    items(1): map[string, uint32];
    label(2): string;
}

/// Empty message (all fields optional, none set).
message EmptyMessage {
    unused_field(1): string;
}

/// Struct with a timestamp field.
struct TimestampedEvent {
    when: timestamp;
    what: string;
}

/// Message with temporal fields.
message ScheduleEntry {
    start(1): timestamp;
    duration(2): duration;
    label(3): string;
}

/// Forward reference coverage: A references B before B is declared.
struct ForwardRefA {
    b: ForwardRefB;
}

struct ForwardRefB {
    value: string;
}

/// Message with deprecated fields that should still round-trip on the wire.
message DeprecatedFieldsMessage {
    current_name(1): string;
    @deprecated("legacy wire compatibility")
    legacy_name(2): string;
    @deprecated
    legacy_enabled(3): bool;
}

/// Integer-key map coverage.
message IntegerKeyMaps {
    labels_by_id(1): map[uint32, string];
    flags_by_id(2): map[int64, bool];
}

/// Nested type used by deep compound collections.
struct NestedLeaf {
    label: string;
}

/// Deeply nested map/array/defined-type composition.
message DeepNestedCollections {
    nested(1): map[string, map[string, NestedLeaf][]];
}

/// Struct with nested byte array (byte[][]).
struct ByteMatrix {
    rows: byte[][];
}

/// Struct with map containing byte array values.
struct ByteTagMap {
    entries: map[string, byte[]];
}

/// Message with byte array field — tests Option<BebopBytes> serde.
message ByteArrayMessage {
    label(1): string;
    payload(2): byte[];
}

/// Message with nested byte arrays and maps.
message ByteCollectionMessage {
    matrix(1): byte[][];
    tagged(2): map[string, byte[]];
}
