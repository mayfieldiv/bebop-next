// collision_types.bop
//
// Adversarial name-collision schema for the Rust code generator (Rust keywords,
// other languages' keywords, and names mirroring bebop_runtime symbols).
// Kept separate from test_types.bop so regenerating this file does not churn
// integration-tests/src/test_types.rs.

edition = "2026"
package test

import "bebop/decorators.bop"

/// Same wire layout as `Point` in test_types.bop; used by `KeywordUnion` only.
struct Point {
    x: float32;
    y: float32;
}

// ---------------------------------------------------------------------------
// Name collision torture: Rust keywords, other language keywords, and names
// that mirror bebop_runtime symbols. The Rust generator must use `::bebop_runtime::…`
// for runtime types and mapped identifiers (`Self_`, `self_`, …) where raw `r#` is invalid.
//
// Bebop reserves some tokens as definition names (struct, enum, union, message,
// const, mut, pub, package, import, export, readonly, etc.); those are omitted.
// ---------------------------------------------------------------------------

// --- Same identifiers as bebop_runtime / prelude (must not resolve via imports) ---
struct Uuid {
    tag: int32;
}
struct HashMap {
    tag: int32;
}
struct DecodeError {
    tag: int32;
}
struct BebopReader {
    tag: int32;
}
struct BebopWriter {
    tag: int32;
}
struct BebopDecode {
    tag: int32;
}
struct BebopEncode {
    tag: int32;
}
struct BebopDuration {
    tag: int32;
}
struct BebopTimestamp {
    tag: int32;
}
struct BebopFlags {
    tag: int32;
}
struct BebopBytes {
    tag: int32;
}
struct serde {
    tag: int32;
}
struct wire {
    tag: int32;
}

