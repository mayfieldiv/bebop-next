/// Many Rust / Swift / C# keywords reused as *field* names (snake_case in Rust).
struct RustKeywordFields {
    type: int32;
    mod: int32;
    self: int32;
    super: int32;
    match: int32;
    where: int32;
    loop: int32;
    move: int32;
    ref: int32;
    dyn: int32;
    use: int32;
    let: int32;
    fn: int32;
    as: int32;
    in: int32;
    is: int32;
    try: int32;
}

// Const names that are Rust keywords (must not collide with struct/enum definitions above).
const uint32 break = 0;
const uint32 continue = 1;
const uint32 return = 2;
const uint32 else = 3;

enum MultiLangKeywordVariant : uint8 {
    mod = 0;
    match = 1;
    type = 2;
    void = 3;
    int = 4;
    await = 5;
    async = 6;
    Self = 7;
    super = 8;
}

@flags
enum RustKeywordFlags : uint8 {
    NONE = 0;
    type = 1;
    mod = 2;
    self = 4;
}

union KeywordUnion {
    mod(1): Point;
    match(2): Point;
}

message KeywordFieldMessage {
    type(1): int32;
    mod(2): string;
    self(3): bool;
}

/// Holds both a wire `guid` (runtime UUID) and a user-defined `Uuid` struct.
struct GuidAndUserUuidCollision {
    runtime_guid: guid;
    user_uuid: Uuid;
}

message MapWithUserHashMapStruct {
    items(1): map[string, HashMap];
}
