{
	"Struct": {
		"prefix": ["struct", "st"],
		"body": [
			"struct ${1:Name} {",
			"\t${2:field}: ${3:type};",
			"}"
		],
		"description": "Define a struct with fixed fields"
	},
	"Message": {
		"prefix": ["message", "msg"],
		"body": [
			"message ${1:Name} {",
			"\t${2:1} -> ${3:field}: ${4:type};",
			"}"
		],
		"description": "Define a message with indexed fields"
	},
	"Message Field": {
		"prefix": ["field", "mf", "->"],
		"body": "${1:1} -> ${2:field}: ${3:type};",
		"description": "Add a field to a message"
	},
	"Enum": {
		"prefix": ["enum", "en"],
		"body": [
			"enum ${1:Name} {",
			"\t${2:Value} = ${3:0};",
			"}"
		],
		"description": "Define an enum"
	},
	"Enum with Base Type": {
		"prefix": ["enumbase", "enb"],
		"body": [
			"enum ${1:Name} : ${2:uint32} {",
			"\t${3:Value} = ${4:0};",
			"}"
		],
		"description": "Define an enum with explicit base type"
	},
	"Flags Enum": {
		"prefix": ["flags", "fl"],
		"body": [
			"@flags",
			"enum ${1:Name} {",
			"\tNone = 0;",
			"\t${2:Flag1} = 1;",
			"\t${3:Flag2} = 2;",
			"\t${4:Flag3} = 4;",
			"}"
		],
		"description": "Define a flags enum"
	},
	"Union": {
		"prefix": ["union", "un"],
		"body": [
			"union ${1:Name} {",
			"\t${2:1} -> struct ${3:Variant1} {",
			"\t\t${4:field}: ${5:type};",
			"\t}",
			"}"
		],
		"description": "Define a discriminated union"
	},
	"Union Branch": {
		"prefix": ["branch", "ub"],
		"body": [
			"${1:1} -> struct ${2:Variant} {",
			"\t${3:field}: ${4:type};",
			"}"
		],
		"description": "Add a branch to a union"
	},
	"Union Branch Reference": {
		"prefix": ["branchref", "ubr"],
		"body": "${1:1} -> ${2:ExistingType};",
		"description": "Add a branch referencing existing type"
	},
	"Service": {
		"prefix": ["service", "svc"],
		"body": [
			"service ${1:Name} {",
			"\t${2:method}(${3:Request}): ${4:Response};",
			"}"
		],
		"description": "Define a service"
	},
	"Service Method": {
		"prefix": ["method", "rpc"],
		"body": "${1:method}(${2:Request}): ${3:Response};",
		"description": "Add a method to a service"
	},
	"Service Stream Method": {
		"prefix": ["stream", "sm"],
		"body": "${1:method}(stream ${2:Request}): stream ${3:Response};",
		"description": "Add a bidirectional streaming method"
	},
	"Const": {
		"prefix": ["const", "co"],
		"body": "const ${1:type} ${2:NAME} = ${3:value};",
		"description": "Define a constant"
	},
	"Const String": {
		"prefix": ["conststr", "cs"],
		"body": "const string ${1:NAME} = \"${2:value}\";",
		"description": "Define a string constant"
	},
	"Import": {
		"prefix": ["import", "imp"],
		"body": "import \"${1:path}\";",
		"description": "Import another schema file"
	},
	"Namespace": {
		"prefix": ["namespace", "ns"],
		"body": [
			"namespace ${1:Name} {",
			"\t$0",
			"}"
		],
		"description": "Define a namespace"
	},
	"Decorator": {
		"prefix": ["@", "dec"],
		"body": "@${1:decorator}",
		"description": "Add a decorator"
	},
	"Deprecated": {
		"prefix": ["deprecated", "dep"],
		"body": "@deprecated(\"${1:reason}\")",
		"description": "Mark as deprecated"
	},
	"Opcode": {
		"prefix": ["opcode", "op"],
		"body": "@opcode(${1:0x01})",
		"description": "Add opcode decorator"
	},
	"Documentation": {
		"prefix": ["doc", "///"],
		"body": "/// ${1:Documentation}",
		"description": "Add documentation comment"
	},
	"Block Comment": {
		"prefix": ["comment", "/*"],
		"body": [
			"/*",
			" * ${1:Comment}",
			" */"
		],
		"description": "Add block comment"
	},
	"Edition": {
		"prefix": ["edition", "ed"],
		"body": "edition = \"${1:2026}\";",
		"description": "Set schema edition"
	},
	"Map Type": {
		"prefix": ["map"],
		"body": "map[${1:string}, ${2:type}]",
		"description": "Map type"
	},
	"Array Type": {
		"prefix": ["array", "arr"],
		"body": "${1:type}[]",
		"description": "Array type"
	},
	"Fixed Array Type": {
		"prefix": ["fixedarray", "farr"],
		"body": "${1:type}[${2:size}]",
		"description": "Fixed-size array type"
	},
	"Request/Response Pair": {
		"prefix": ["reqres", "rr"],
		"body": [
			"message ${1:Name}Request {",
			"\t1 -> ${2:field}: ${3:type};",
			"}",
			"",
			"message ${1:Name}Response {",
			"\t1 -> ${4:result}: ${5:type};",
			"}"
		],
		"description": "Create request/response message pair"
	},
	"CRUD Service": {
		"prefix": ["crud"],
		"body": [
			"message ${1:Entity} {",
			"\t1 -> id: uuid;",
			"\t2 -> ${2:field}: ${3:type};",
			"}",
			"",
			"message Create${1:Entity}Request {",
			"\t1 -> ${2:field}: ${3:type};",
			"}",
			"",
			"message Get${1:Entity}Request {",
			"\t1 -> id: uuid;",
			"}",
			"",
			"message Update${1:Entity}Request {",
			"\t1 -> id: uuid;",
			"\t2 -> ${2:field}: ${3:type};",
			"}",
			"",
			"message Delete${1:Entity}Request {",
			"\t1 -> id: uuid;",
			"}",
			"",
			"message ${1:Entity}Response {",
			"\t1 -> entity: ${1:Entity};",
			"}",
			"",
			"service ${1:Entity}Service {",
			"\tcreate(Create${1:Entity}Request): ${1:Entity}Response;",
			"\tget(Get${1:Entity}Request): ${1:Entity}Response;",
			"\tupdate(Update${1:Entity}Request): ${1:Entity}Response;",
			"\tdelete(Delete${1:Entity}Request): ${1:Entity}Response;",
			"}"
		],
		"description": "Generate CRUD service boilerplate"
	}
}
