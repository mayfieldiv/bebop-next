{
  "include": ["./Valid/*.bop"],
  "exclude": ["./ShouldFail"],
  "generators": [
    {
      "alias": "cs",
      "outFile": "csoutput/models.cs"
    },
    {
      "alias": "ts",
      "outFile": "tsoutput/models.ts"
    },
    {
      "alias": "py",
      "outFile": "pyoutput/models.py"
    }
  ]
}
